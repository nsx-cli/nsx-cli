{
  "name": "@nsxservicos/cli",
  "version": "2.0.0",
  "description": "NSX Platform CLI",
  "license": "MIT",
  "author": "NSX Team",
  "main": "dist/index.js",
  "type": "commonjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "nsx": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "SECURITY.md",
    "CONTRIBUTING.md",
    "RELEASE_NOTES.md",
    "RELEASE_NOTES.v1.0.md",
    "CHECKLIST.v1.0.md",
    "RC1.md",
    "docs"
  ],
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "cli",
    "nestjs",
    "prisma",
    "ts-morph",
    "codegen",
    "architecture",
    "typescript",
    "generator",
    "scaffold",
    "backend",
    "developer-tools"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nsx-platform/nsx-cli.git"
  },
  "homepage": "https://github.com/nsx-platform/nsx-cli#readme",
  "bugs": {
    "url": "https://github.com/nsx-platform/nsx-cli/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc && node scripts/copy-assets.js",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run --exclude src/**/*.integration.test.ts --exclude src/smoke/**/*.test.ts",
    "test:integration": "vitest run src/commands/prisma.command.integration.test.ts",
    "test:smoke": "vitest run src/smoke/cli-smoke.test.ts",
    "test:coverage": "vitest run --coverage",
    "prepack": "npm run build",
    "release:check": "npm run build && npm run test:unit && npm run test:integration && npm run test:smoke",
    "release:npm:dry-run": "npm publish --dry-run"
  },
  "dependencies": {
    "@prisma/internals": "^6.13.0",
    "chalk": "^5.6.2",
    "change-case": "^5.4.4",
    "commander": "^14.0.3",
    "eslint": "^10.7.0",
    "execa": "^9.6.1",
    "fs-extra": "^11.3.6",
    "glob": "^11.0.3",
    "handlebars": "^4.7.9",
    "inquirer": "^12.11.1",
    "ora": "^8.2.0",
    "pluralize": "^8.0.0",
    "prettier": "^3.9.5",
    "ts-morph": "^25.0.1"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/handlebars": "^4.0.40",
    "@types/node": "^24.0.15",
    "@types/pluralize": "^0.0.33",
    "@types/prettier": "^2.7.3",
    "@vitest/coverage-v8": "^2.1.8",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^2.1.8"
  }
}
