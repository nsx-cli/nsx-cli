{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "rootDir": "src",
    "outDir": "dist",

    "strict": true,

    "esModuleInterop": true,

    "resolveJsonModule": true,

    "skipLibCheck": true
  },

  "include": [
    "src/**/*.ts"
  ],

  "exclude": [
    "**/*.test.ts",
    "**/*.integration.test.ts",
    "**/*.coverage.test.ts",
    "src/smoke/**",
    "coverage",
    "dist",
    "node_modules"
  ]
}