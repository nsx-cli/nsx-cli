model Empresa {

  id                       String         @id @default(uuid())
  razaoSocial              String         
  nomeFantasia             String?        
  cnpj                     String?        @unique
  inscricaoEstadual        String?        
  email                    String?        
  telefone                 String?        
  celular                  String?        
  cep                      String?        
  logradouro               String?        
  numero                   String?        
  complemento              String?        
  bairro                   String?        
  cidade                   String?        
  estado                   String?        
  pais                     String?        @default("Brasil")
  ativo                    Boolean?       @default(true)
  createdAt                DateTime?      @default(now())
  updatedAt                DateTime?      @updatedAt

  @@map("empresas")
}